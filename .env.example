# SiteMap Guard v2 Configuration
# Copy this file to .env and fill in your API keys

# ── Optional API Keys (tool works without these) ──────────────────────
# Get free key: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFEBROWSING_API_KEY=

# Get free key: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# ── Performance Settings ──────────────────────────────────────────────
MAX_CRAWL_DEPTH=3
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT=10
RESPECT_ROBOTS_TXT=true
USER_AGENT=SiteMapGuard/2.0 (+https://github.com/sitemap-guard; security-scanner)

# ── Bloom Filter (URL dedup) ─────────────────────────────────────────
BLOOM_FILTER_CAPACITY=1000000
BLOOM_FILTER_ERROR_RATE=0.001

# ── Analyzer Toggles ─────────────────────────────────────────────────
ENABLE_SSL_ANALYZER=true
ENABLE_HEADERS_ANALYZER=true
ENABLE_CONTENT_ANALYZER=true
ENABLE_DNS_ANALYZER=true
ENABLE_TECH_DETECTOR=true
ENABLE_SAFEBROWSING=false
ENABLE_VIRUSTOTAL=false
ENABLE_PHISHTANK=true

# ── Output Settings ──────────────────────────────────────────────────
OUTPUT_DIR=./reports
REPORT_FORMAT=html
